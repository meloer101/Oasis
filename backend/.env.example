DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
REFRESH_TOKEN_EXPIRES_DAYS=30
PORT=3001
NODE_ENV=development
# CORS: must match the origin you use in the browser (scheme + host + port, no trailing slash). If empty, defaults to http://localhost:3000. In development, localhost:3000, 127.0.0.1:3000, and private LAN origins are also permitted.
FRONTEND_URL=http://localhost:3000

# Image upload (Supabase Storage)
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
